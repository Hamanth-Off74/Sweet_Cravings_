# API Configuration
# Get your backend URL from your hosting provider (Railway, Render, etc.)
# Example: https://sweet-cravings-api.railway.app
VITE_API_BASE_URL=https://your-backend-url.com

# Clerk Authentication
# Get your key from: https://dashboard.clerk.com/
# Navigate to: API Keys section and copy your Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
