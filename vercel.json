{
    "version": 2,
    "builds": [
      {
        "src": "client/vite.config.js",
        "use": "@vercel/static-build",
        "configuration": {
          "installCommand": "npm --prefix client install",
          "outputDirectory": "client/dist"
        }
      },
      {
        "src": "app.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/app.js"
      },
      {
        "src": "/(.*)",
        "dest": "/client/dist/$1"
      }
    ]
  }
