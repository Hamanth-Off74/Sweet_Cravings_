<%- include('partials/header') %>

<div class="admin-page">
    <div class="container">
        <div class="admin-header">
            <h1><i class="fas fa-chart-line"></i> Admin Dashboard</h1>
            <p>View and manage all orders</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-shopping-cart"></i>
                <div class="stat-info">
                    <h3><%= orders.length %></h3>
                    <p>Total Orders</p>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-rupee-sign"></i>
                <div class="stat-info">
                    <h3>₹<%= orders.reduce((sum, order) => sum + order.total, 0).toFixed(2) %></h3>
                    <p>Total Revenue</p>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-clock"></i>
                <div class="stat-info">
                    <h3><%= orders.filter(o => o.orderStatus === 'pending').length %></h3>
                    <p>Pending Orders</p>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-check-circle"></i>
                <div class="stat-info">
                    <h3><%= orders.filter(o => o.orderStatus === 'delivered').length %></h3>
                    <p>Delivered</p>
                </div>
            </div>
        </div>

        <div class="orders-table-container">
            <h2>All Orders</h2>
            
            <% if (orders.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h3>No Orders Yet</h3>
                    <p>Orders will appear here once customers place them.</p>
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="orders-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Payment</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td><strong><%= order.orderId %></strong></td>
                                    <td><%= order.customer.firstName %> <%= order.customer.lastName %></td>
                                    <td><%= order.customer.email %></td>
                                    <td><%= order.customer.phone %></td>
                                    <td><%= order.items.length %> items</td>
                                    <td><strong>₹<%= order.total.toFixed(2) %></strong></td>
                                    <td>
                                        <span class="badge <%= order.paymentStatus === 'paid' ? 'badge-success' : 'badge-warning' %>">
                                            <%= order.paymentStatus %>
                                        </span>
                                        <br>
                                        <small><%= order.paymentMethod %></small>
                                    </td>
                                    <td>
                                        <span class="badge badge-<%= order.orderStatus %>">
                                            <%= order.orderStatus %>
                                        </span>
                                    </td>
                                    <td><%= new Date(order.createdAt).toLocaleString() %></td>
                                    <td>
                                        <button class="btn-icon" onclick="viewOrderDetails('<%= order._id %>')" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Order Details Modal -->
<div id="order-details-modal" class="modal" style="display: none;">
    <div class="modal-content">
        <span class="close-modal" onclick="closeOrderModal()">&times;</span>
        <div id="order-details-content">
            <!-- Details will be loaded here -->
        </div>
    </div>
</div>

<style>
.admin-page {
    padding: 120px 0 80px;
    min-height: 100vh;
}

.admin-header {
    text-align: center;
    margin-bottom: 40px;
}

.admin-header h1 {
    font-size: 2.5rem;
    color: var(--dark-color);
    margin-bottom: 10px;
}

.admin-header p {
    color: #666;
    font-size: 1.1rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.stat-card {
    background: white;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    display: flex;
    align-items: center;
    gap: 20px;
    transition: transform 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
}

.stat-card i {
    font-size: 3rem;
    color: var(--primary-color);
    background: linear-gradient(135deg, rgba(255,97,97,0.1), rgba(255,154,158,0.1));
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
}

.stat-info h3 {
    font-size: 2rem;
    color: var(--dark-color);
    margin: 0;
}

.stat-info p {
    color: #666;
    margin: 5px 0 0;
}

.orders-table-container {
    background: white;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.orders-table-container h2 {
    margin-bottom: 20px;
    color: var(--dark-color);
}

.table-responsive {
    overflow-x: auto;
}

.orders-table {
    width: 100%;
    border-collapse: collapse;
}

.orders-table thead {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
}

.orders-table th {
    padding: 15px;
    text-align: left;
    color: white;
    font-weight: 600;
    white-space: nowrap;
}

.orders-table td {
    padding: 15px;
    border-bottom: 1px solid #eee;
}

.orders-table tbody tr:hover {
    background: #f8f9fa;
}

.badge {
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: capitalize;
}

.badge-success {
    background: #d4edda;
    color: #155724;
}

.badge-warning {
    background: #fff3cd;
    color: #856404;
}

.badge-pending {
    background: #fff3cd;
    color: #856404;
}

.badge-processing {
    background: #cce5ff;
    color: #004085;
}

.badge-shipped {
    background: #d1ecf1;
    color: #0c5460;
}

.badge-delivered {
    background: #d4edda;
    color: #155724;
}

.badge-cancelled {
    background: #f8d7da;
    color: #721c24;
}

.btn-icon {
    background: var(--primary-color);
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-icon:hover {
    background: var(--secondary-color);
    transform: scale(1.1);
}

.empty-state {
    text-align: center;
    padding: 60px 20px;
}

.empty-state i {
    font-size: 4rem;
    color: #ccc;
    margin-bottom: 20px;
}

.empty-state h3 {
    color: var(--dark-color);
    margin-bottom: 10px;
}

.empty-state p {
    color: #666;
}

@media (max-width: 768px) {
    .admin-page {
        padding: 100px 0 60px;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
    
    .orders-table-container {
        padding: 20px;
    }
    
    .orders-table {
        font-size: 0.85rem;
    }
    
    .orders-table th,
    .orders-table td {
        padding: 10px 8px;
    }
}
</style>

<script>
function viewOrderDetails(orderId) {
    // Implement order details view
    alert('View details for order: ' + orderId);
}

function closeOrderModal() {
    document.getElementById('order-details-modal').style.display = 'none';
}
</script>

<%- include('partials/footer') %>
