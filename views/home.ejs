<%- include('partials/header') %>

<!-- Welcome Screen Overlay -->
<div class="welcome-overlay" id="welcome-overlay">
    <div class="welcome-content">
        <div class="welcome-animation">
            <i class="fas fa-birthday-cake welcome-icon"></i>
        </div>
        <h1 class="welcome-title">WELCOME TO</h1>
        <h2 class="welcome-brand">SWEETCRAVINGS</h2>
        <p class="welcome-tagline">Indulge in Pure Sweetness</p>
        <div class="welcome-loader">
            <div class="loader-bar"></div>
        </div>
    </div>
</div>

<div class="slideshow-container">
    <% if (typeof featured !== 'undefined' && featured.length > 0) { %>
        <% featured.forEach((dessert, index) => { %>
            <div class="slide fade">
                <div class="slide-content">
                    <div class="slide-image">
                        <img src="<%= dessert.imageURL %>" alt="<%= dessert.name %>">
                    </div>
                    <div class="slide-text">
                        <h1><%= dessert.name %></h1>
                        <p><%= dessert.description %></p>
                        <div class="slide-price">
                            <span class="current-price">₹<%= dessert.price.toFixed(2) %></span>
                            <% if (dessert.originalPrice) { %>
                                <span class="original-price">₹<%= dessert.originalPrice.toFixed(2) %></span>
                            <% } %>
                        </div>
                        <div class="slide-buttons">
                             <a href="/menu" class="btn btn-primary">
                                <i class="fas fa-shopping-cart"></i> Order Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>

        <!-- Navigation arrows -->
        <div class="slide-nav">
            <button class="slide-btn prev" onclick="changeSlide(-1)">
                <i class="fas fa-chevron-left"></i>
            </button>
            <button class="slide-btn next" onclick="changeSlide(1)">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>

        <!-- Slide indicators -->
        <div class="slide-indicators">
            <% featured.forEach((_, index) => { %>
                <span class="indicator" data-index="<%= index + 1 %>" onclick="currentSlide(this.dataset.index)"></span>
            <% }); %>
        </div>
    <% } else { %>
        <div class="slide active">
            <div class="slide-content">
                <div class="slide-image">
                    <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=800&h=600&fit=crop" alt="Premium Cakes">
                </div>
                <div class="slide-text">
                    <h1>Welcome to SweetCravings</h1>
                    <p>Indulge in our handcrafted desserts made with the finest ingredients.</p>
                    <div class="slide-buttons">
                        <a href="/menu" class="btn btn-primary">
                            <i class="fas fa-shopping-cart"></i> Explore Menu
                        </a>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>


<div class="products-section" id="features">
    <div class="container">
        <h2 class="section-title">Featured Desserts</h2>
        
        <div class="dessert-grid">
             <% if (typeof desserts !== 'undefined' && desserts.length > 0) { %>
                <% desserts.forEach(dessert => { %>
                    <div class="dessert-card" data-category="<%= dessert.category.toLowerCase() %>" data-price="<%= dessert.price %>" data-rating="<%= dessert.rating %>">
                        <div class="dessert-image">
                            <img src="<%= dessert.imageURL %>" alt="<%= dessert.name %>">
                            <% if (dessert.discount > 0) { %>
                                <div class="discount-badge"><%= dessert.discount %>% OFF</div>
                            <% } %>
                             <button class="add-to-wishlist-btn" data-id="<%= dessert._id %>">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                        <div class="dessert-info">
                            <h3 class="dessert-name"><%= dessert.name %></h3>
                            <p class="dessert-description"><%= dessert.description.substring(0, 60) %>...</p>
                            
                            <div class="rating-section">
                                <div class="star-rating" data-rating="<%= dessert.rating %>">
                                    <span class="rating-value"><i class="fas fa-star"></i> <%= dessert.rating %></span>
                                </div>
                                <span class="reviews-count">(<%= dessert.reviews %>)</span>
                            </div>
                            
                            <div class="price-section">
                                <span class="current-price">₹<%= dessert.price.toFixed(2) %></span>
                                <% if (dessert.originalPrice && dessert.originalPrice > dessert.price) { %>
                                    <span class="original-price">₹<%= dessert.originalPrice.toFixed(2) %></span>
                                <% } %>
                            </div>
                             <% if (dessert.deliveryTime) { %>
                                <div class="delivery-info">
                                    <i class="fas fa-truck"></i> Delivery in <%= dessert.deliveryTime %>
                                </div>
                            <% } %>
                            
                            <div class="card-actions">
                                <button class="add-to-cart-btn" 
                                        data-id="<%= dessert._id %>" 
                                        data-name="<%= dessert.name %>" 
                                        data-price="<%= dessert.price %>" 
                                        data-image="<%= dessert.imageURL %>">
                                    <i class="fas fa-shopping-cart"></i> Add to Cart
                                </button>
                                <button class="view-reviews-btn" data-id="<%= dessert._id %>">Reviews</button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p>No desserts to display.</p>
            <% } %>
        </div>
        
        <div style="text-align: center; margin-top: 40px;">
            <a href="/menu" class="btn btn-secondary">
                <i class="fas fa-eye"></i> View All Desserts
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
