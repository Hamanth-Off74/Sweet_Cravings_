<%- include('partials/header') %>

<div class="orders-page">
    <div class="container">
        <div class="page-header">
            <h1>My Orders</h1>
            <p>Track your order status and view order history</p>
        </div>

        <!-- Order Filters -->
        <div class="order-filters">
            <button class="order-filter-btn active" data-filter="all">All Orders</button>
            <button class="order-filter-btn" data-filter="pending">Pending</button>
            <button class="order-filter-btn" data-filter="processing">Processing</button>
            <button class="order-filter-btn" data-filter="shipped">Shipped</button>
            <button class="order-filter-btn" data-filter="delivered">Delivered</button>
            <button class="order-filter-btn" data-filter="cancelled">Cancelled</button>
        </div>

        <!-- Orders List -->
        <div class="orders-container" id="orders-container">
            <!-- Orders will be populated by JavaScript -->
        </div>

        <!-- Empty Orders State -->
        <div class="empty-orders" id="empty-orders" style="display: none;">
            <div class="empty-icon">
                <i class="fas fa-shopping-bag"></i>
            </div>
            <h3>No Orders Found</h3>
            <p>You haven't placed any orders yet. Start shopping to see your orders here!</p>
            <a href="/menu" class="btn btn-primary">Start Shopping</a>
        </div>
    </div>
</div>

<!-- Order Details Modal -->
<div class="modal-overlay" id="order-details-modal">
    <div class="modal-content order-modal">
        <div class="modal-header">
            <h2>Order Details</h2>
            <span class="close-modal">&times;</span>
        </div>
        <div class="modal-body" id="order-details-content">
            <!-- Order details will be populated here -->
        </div>
    </div>
</div>

<%- include('partials/footer') %>