<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SweetCravings - Premium Desserts Online</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- Background Slideshow with Product Items -->
    <div class="bg-slideshow">
        <!-- Slide 1: Premium Cakes Collection -->
        <div class="bg-slide active">
            <div class="bg-slide-item">
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=600&h=600&fit=crop" alt="Chocolate Cake">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">18% OFF</span>
                        <h3>Chocolate Cake</h3>
                        <p>Rich and moist chocolate cake with layers of chocolate ganache</p>
                        <div class="bg-price">₹180.00 <span class="bg-old-price">₹220.00</span></div>
                    </div>
                </div>
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1614707267537-b85aaf00c4b7?w=600&h=600&fit=crop" alt="Red Velvet Cake">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">17% OFF</span>
                        <h3>Red Velvet Cake</h3>
                        <p>Classic red velvet cake with smooth cream cheese frosting</p>
                        <div class="bg-price">₹150.00 <span class="bg-old-price">₹180.00</span></div>
                    </div>
                </div>
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1606890737921-8fc77c8ea8c5?w=600&h=600&fit=crop" alt="Black Forest Cake">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">14% OFF</span>
                        <h3>Black Forest Cake</h3>
                        <p>Decadent chocolate cake with cherries and whipped cream</p>
                        <div class="bg-price">₹190.00 <span class="bg-old-price">₹220.00</span></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Slide 2: Delightful Desserts -->
        <div class="bg-slide">
            <div class="bg-slide-item">
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1533134486753-c833f0ed4866?w=600&h=600&fit=crop" alt="Cheesecake">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">16% OFF</span>
                        <h3>Cheesecake</h3>
                        <p>Creamy and smooth New York style cheesecake</p>
                        <div class="bg-price">₹160.00 <span class="bg-old-price">₹190.00</span></div>
                    </div>
                </div>
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1535920527002-b35e96722eb9?w=600&h=600&fit=crop" alt="Blueberry Pie">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">16% OFF</span>
                        <h3>Blueberry Pie</h3>
                        <p>Fresh blueberry pie with flaky golden crust</p>
                        <div class="bg-price">₹160.00 <span class="bg-old-price">₹190.00</span></div>
                    </div>
                </div>
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1499636136210-6f4ee915583e?w=600&h=600&fit=crop" alt="Chocolate Chip Cookie">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">20% OFF</span>
                        <h3>Chocolate Chip Cookie</h3>
                        <p>Classic chocolate chip cookies - soft, chewy, and delicious</p>
                        <div class="bg-price">₹40.00 <span class="bg-old-price">₹50.00</span></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Slide 3: Sweet Treats -->
        <div class="bg-slide">
            <div class="bg-slide-item">
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=600&h=600&fit=crop" alt="Fruit Tart">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">14% OFF</span>
                        <h3>Fruit Tart</h3>
                        <p>Fresh fruit tart with custard filling and buttery crust</p>
                        <div class="bg-price">₹180.00 <span class="bg-old-price">₹210.00</span></div>
                    </div>
                </div>
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1607920591413-4ec007e70023?w=600&h=600&fit=crop" alt="Fudgy Brownie">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">20% OFF</span>
                        <h3>Fudgy Brownie</h3>
                        <p>Ultra-rich chocolate brownies with fudgy center</p>
                        <div class="bg-price">₹80.00 <span class="bg-old-price">₹100.00</span></div>
                    </div>
                </div>
                <div class="bg-product-card">
                    <img src="https://images.unsplash.com/photo-1563805042-7684c019e1cb?w=600&h=600&fit=crop" alt="Vanilla Ice Cream">
                    <div class="bg-item-info">
                        <span class="bg-discount-badge">14% OFF</span>
                        <h3>Vanilla Ice Cream</h3>
                        <p>Premium vanilla ice cream made with real vanilla beans</p>
                        <div class="bg-price">₹120.00 <span class="bg-old-price">₹140.00</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="bg-overlay"></div>
    <header class="header">
        <div class="top-bar">
            <div class="container">
                <div class="top-links">
                    <span><i class="fas fa-truck"></i> Free Delivery on orders above ₹500</span>
                    <span><i class="fas fa-phone"></i> Customer Support: 1800-123-4567</span>
                    <span><i class="fas fa-store"></i> Become a Seller</span>
                </div>
            </div>
        </div>
        <nav class="navbar">
            <div class="container">
                <div class="nav-brand">
                    <a href="/" class="logo">
                        <i class="fas fa-birthday-cake"></i>
                        SweetCravings
                    </a>
                </div>
                
                <div class="search-bar">
                    <input type="text" placeholder="Search for desserts, cakes, cookies..." id="search-input">
                    <button type="button" class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
                
                <div class="nav-actions">
                    <div id="guest-actions">
                        <button class="btn btn-nav" id="login-btn" onclick="showLoginModal()">Login</button>
                        <button class="btn btn-nav btn-outline" id="signup-btn" onclick="showRegisterModal()">Sign Up</button>
                    </div>
                    
                    <div id="user-actions" style="display: none;">
                         <!-- User Account Dropdown -->
                        <div class="nav-dropdown" id="account-dropdown">
                            <a href="#" class="nav-link dropdown-trigger" id="account-trigger">
                                <i class="fas fa-user-circle"></i>
                                <span id="user-name-display">My Account</span>
                                <i class="fas fa-chevron-down"></i>
                            </a>
                            <div class="dropdown-menu" id="account-menu">
                                <div class="dropdown-items">
                                    <a href="/orders" class="dropdown-item">
                                        <i class="fas fa-box"></i> My Orders
                                    </a>
                                    <a href="#" class="dropdown-item" onclick="showWishlist()">
                                        <i class="fas fa-heart"></i> Wishlist
                                    </a>
                                    <a href="#" class="dropdown-item" onclick="logout()">
                                        <i class="fas fa-sign-out-alt"></i> Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Wishlist -->
                    <a href="#" class="nav-link icon-link" onclick="showWishlist()">
                        <i class="fas fa-heart"></i>
                        <span class="wishlist-count" id="wishlist-count">0</span>
                    </a>

                    <!-- Cart -->
                    <a href="/cart" class="nav-link icon-link cart-link">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count" id="cart-count">0</span>
                    </a>
                </div>
            </div>
        </nav>

        <!-- Category Navigation -->
        <div class="category-nav">
            <div class="container">
                <div class="category-links">
                    <a href="/menu" class="category-link">
                        <i class="fas fa-birthday-cake"></i> Cakes
                    </a>
                    <a href="/menu" class="category-link">
                        <i class="fas fa-cookie-bite"></i> Cookies
                    </a>
                    <a href="/menu" class="category-link">
                        <i class="fas fa-chart-pie"></i> Pies
                    </a>
                    <a href="/menu" class="category-link">
                        <i class="fas fa-pizza-slice"></i> Italian
                    </a>
                    <a href="/menu" class="category-link">
                        <i class="fas fa-square"></i> Brownies
                    </a>
                    <a href="/menu" class="category-link">
                        <i class="fas fa-circle"></i> Tarts
                    </a>
                    <a href="/menu" class="category-link">
                        <i class="fas fa-ice-cream"></i> Ice Cream
                    </a>
                    <a href="#" class="category-link sale-link">
                        <i class="fas fa-tags"></i> Sale
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Login Modal -->
    <div id="login-modal" class="modal">
        <div class="modal-content auth-modal">
            <div class="modal-header">
                <h2>Login</h2>
                <span class="close" onclick="closeModal('login-modal')">&times;</span>
            </div>
            <div class="modal-body">
                <form id="login-form">
                    <div class="form-group">
                        <label for="login-email">Email or Mobile Number</label>
                        <input type="text" id="login-email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="login-password">Password</label>
                        <input type="password" id="login-password" name="password" required>
                    </div>
                    <div class="form-options">
                        <label class="checkbox-label">
                            <input type="checkbox" name="remember"> Remember me
                        </label>
                        <a href="#" class="forgot-password">Forgot Password?</a>
                    </div>
                    <button type="submit" class="btn btn-primary full-width">Login</button>
                </form>
                <div class="auth-divider">
                    <span>OR</span>
                </div>
                <button class="btn btn-secondary full-width" onclick="showRegisterModal(); closeModal('login-modal')">
                    Create New Account
                </button>
            </div>
        </div>
    </div>

    <!-- Register Modal -->
    <div id="register-modal" class="modal">
        <div class="modal-content auth-modal">
            <div class="modal-header">
                <h2>Sign Up</h2>
                <span class="close" onclick="closeModal('register-modal')">&times;</span>
            </div>
            <div class="modal-body">
                <form id="register-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="register-firstname">First Name</label>
                            <input type="text" id="register-firstname" name="firstname" required>
                        </div>
                        <div class="form-group">
                            <label for="register-lastname">Last Name</label>
                            <input type="text" id="register-lastname" name="lastname" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="register-email">Email</label>
                        <input type="email" id="register-email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="register-mobile">Mobile Number</label>
                        <input type="tel" id="register-mobile" name="mobile" required>
                    </div>
                    <div class="form-group">
                        <label for="register-password">Password</label>
                        <input type="password" id="register-password" name="password" required>
                    </div>
                    <div class="form-group">
                        <label for="register-confirm-password">Confirm Password</label>
                        <input type="password" id="register-confirm-password" name="confirmPassword" required>
                    </div>
                    <div class="form-group">
                        <label class="checkbox-label">
                            <input type="checkbox" name="terms" required> 
                            I agree to the <a href="#" class="terms-link">Terms of Service</a> and <a href="#" class="terms-link">Privacy Policy</a>
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary full-width">Create Account</button>
                </form>
                <div class="auth-divider">
                    <span>OR</span>
                </div>
                <button class="btn btn-secondary full-width" onclick="showLoginModal(); closeModal('register-modal')">
                    Already have an account? Login
                </button>
            </div>
        </div>
    </div>

    <!-- Wishlist Modal -->
    <div id="wishlist-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fas fa-heart"></i> My Wishlist</h2>
                <span class="close" onclick="closeModal('wishlist-modal')">&times;</span>
            </div>
            <div class="modal-body">
                <div id="wishlist-items">
                    <div class="empty-state">
                        <i class="fas fa-heart-broken"></i>
                        <h3>Your wishlist is empty</h3>
                        <p>Add items that you like to your wishlist. Review them anytime and easily move them to cart.</p>
                        <a href="/menu" class="btn btn-primary">Browse Desserts</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <main>
